# Configuration de la base de données SQL Server
DB_SERVER=localhost
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourStrongPassword123
DB_NAME=STA_SAV_DB

# Configuration JWT
JWT_SECRET=votre_secret_jwt_tres_securise_changez_moi

# Configuration du serveur
PORT=3000
NODE_ENV=development

# Configuration Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-app-password
SMTP_FROM=noreply@sta-chery.tn

# Configuration SMS (Twilio ou autre fournisseur)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Configuration Hugging Face - Option 1 (Inference API recommandé)
HUGGINGFACE_MODEL_ID=dali444444/chery-sav-qwen2.5-3b-lora
HUGGINGFACE_API_TOKEN=hf_votre_token_ici

# Optionnel: forcer une URL inference explicite
# HUGGINGFACE_INFERENCE_URL=https://api-inference.huggingface.co/models/dali444444/chery-sav-qwen2.5-3b-lora

# Optionnel: utiliser le router HF au lieu de api-inference
# HUGGINGFACE_USE_ROUTER=false

# Optionnel: réglages génération
# HUGGINGFACE_MAX_NEW_TOKENS=300
# HUGGINGFACE_TEMPERATURE=0.7
# HUGGINGFACE_TOP_P=0.9

# Option 2 (Space HF) - laisser commenté si vous utilisez Inference API
# HUGGINGFACE_API_URL=https://votre-modele.hf.space/chat

# Option 3 (Local API: FastAPI + LoRA)
# HUGGINGFACE_API_URL=http://127.0.0.1:8000/chat
# HUGGINGFACE_TIMEOUT_MS=120000

# Configuration WhatsApp
WHATSAPP_SESSION_NAME=session-sta-chery-otp
