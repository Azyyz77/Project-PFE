{
  "name": "backend",
  "version": "1.0.0",
  "description": "Serveur monolithique - STA Chery Tunisia",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:unit": "jest --selectProjects unit --forceExit",
    "test:integration": "jest --selectProjects integration --forceExit",
    "test:coverage": "jest --selectProjects unit --coverage --forceExit",
    "test:coverage:all": "jest --coverage --forceExit",
    "test:watch": "jest --selectProjects unit --watch",
    "test:ci": "jest --selectProjects unit --coverage --ci --forceExit",
    "test:load": "artillery run tests/load/artillery.yml",
    "test:load:report": "artillery run tests/load/artillery.yml --output tests/load/report.json && artillery report tests/load/report.json --output tests/load/report.html",
    "test:ai": "node tests/aiAssistant.test.js",
    "test:model": "node test-mon-modele.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "axios": "^1.14.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "msnodesqlv8": "^5.1.5",
    "mssql": "^9.3.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "node-llama-cpp": "^3.18.1",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "qrcode-terminal": "^0.12.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^2.0.22",
    "supertest": "^7.2.2"
  }
}
